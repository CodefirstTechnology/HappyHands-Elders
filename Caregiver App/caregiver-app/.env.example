# Use your PC's LAN IP when testing on a physical phone (not localhost).
# Find IP: ipconfig (Windows) → IPv4 Address
# Replace with your PC IPv4 from ipconfig (same Wi‑Fi as the phone).
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

# Google Maps SDK key for native map tiles (Android/iOS).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Optional styled map (only if Map ID is enabled for Android/iOS in Cloud Console).
EXPO_PUBLIC_GOOGLE_MAP_ID=your_google_map_id
# Set to true only when Map ID is configured for mobile SDKs (wrong ID causes 403 tiles).
# EXPO_PUBLIC_USE_GOOGLE_MAP_ID=true
