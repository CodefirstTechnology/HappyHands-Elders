# Copy to .env on the VPS and fill in all secrets before first deploy.
# docker compose --env-file .env up -d --build

# --- Host nginx upstream ports (localhost only) ---
ELDERCARE_API_PORT=15000
ELDERCARE_WEBSITE_PORT=15001
ELDERCARE_COORDINATOR_PORT=15002

# --- Public URLs (used at build time for frontends + CORS) ---
WEBSITE_DOMAIN=eldercare.example.com
COORDINATOR_DOMAIN=coordinator.eldercare.example.com
API_DOMAIN=api.eldercare.example.com

VITE_API_BASE_URL=https://api.eldercare.example.com/api/v1
VITE_API_HOST=https://api.eldercare.example.com
VITE_COORDINATOR_PORTAL_URL=https://coordinator.eldercare.example.com
VITE_PARENT_APP_URL=#
VITE_CAREGIVER_APP_URL=#
VITE_PLAY_STORE_PARENT=#
VITE_PLAY_STORE_CAREGIVER=#
VITE_APP_STORE_PARENT=#
VITE_APP_STORE_CAREGIVER=#

# Comma-separated browser origins allowed by the API (website + coordinator portal)
CLIENT_URL=https://eldercare.example.com,https://coordinator.eldercare.example.com

# --- PostgreSQL ---
POSTGRES_USER=eldercare
POSTGRES_PASSWORD=change_me_strong_db_password
POSTGRES_DB=Eldercare_db
# Required when password has @ # : / etc. Encode @ as %40, # as %23, : as %3A
# DATABASE_URL=postgresql://eldercare:your%40password@postgres:5432/Eldercare_db

# --- Auth (min 32 chars each) ---
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Email (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Push notifications (optional) ---
FCM_SERVER_KEY=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=
GOOGLE_MAP_ID=

# --- SMS (production: use msg91 or twilio; set SMS_ALLOW_DEV_OTP=false) ---
SMS_PROVIDER=msg91
SMS_DEFAULT_COUNTRY_CODE=91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=ELDRCA
MSG91_ROUTE=4
MSG91_TEMPLATE_ID_CARE_OTP=
SMS_ALLOW_DEV_OTP=false

# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

CAREGIVER_COORDINATOR_RADIUS_KM=3
MAX_CHILDREN_DEFAULT=4
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=800
