NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/Eldercare_db
JWT_SECRET=your_jwt_secret_32chars_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_32chars_minimum
JWT_REFRESH_EXPIRES_IN=7d
REDIS_URL=redis://localhost:6379
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FCM_SERVER_KEY=your_fcm_key
# Local folder for ID proof & profile photos; DB stores paths like /uploads/<filename>
UPLOAD_DIR=uploads
# Comma-separated browser origins (coordinator portal, Expo web). In dev, any localhost port is also allowed.
CLIENT_URL=http://localhost:5173,http://localhost:5174,http://localhost:8081
# Set true when running behind nginx/reverse proxy (Docker production sets this automatically)
TRUST_PROXY=false
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Enable in Cloud Console: Places API, Geocoding API, Maps SDK for Android/iOS (mobile apps).
# Optional: Static Maps API if using GET /geo/map-preview
GOOGLE_MAP_ID=your_google_map_id

# Caregiver ↔ coordinator proximity radius (km) for registration routing and caregiver search
CAREGIVER_COORDINATOR_RADIUS_KM=3
MAX_CHILDREN_DEFAULT=4

# Aadhaar Offline XML (UIDAI Paperless e-KYC) — free verification
# Download cert: https://uidai.gov.in/images/uidai_offline_publickey_26022019.cer → Backend/certs/
UIDAI_OFFLINE_CERT_PATH=certs/uidai_offline_publickey.cer
# Family clients only see caregivers with aadhaarVerified=true when listing (set false to disable)
REQUIRE_AADHAAR_VERIFICATION=true

# SMS for care-start OTP (sent to family client's registered mobile)
# Provider: msg91 (recommended for India) | twilio | log
SMS_PROVIDER=msg91
SMS_DEFAULT_COUNTRY_CODE=91
# MSG91 — https://msg91.com (DLT template ID for care-start OTP)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=CHLDRA
MSG91_ROUTE=4
MSG91_TEMPLATE_ID_CARE_OTP=your_dlt_care_otp_template_id
# Twilio (alternative)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1234567890
# Show OTP in API response when SMS is log-only (dev fallback). Set false in production.
SMS_ALLOW_DEV_OTP=true
